@{ 
    var rnd = new Random();
    int number = (int)ViewData["number"];
    if (number == 0) number = 10;
}

<h3>I'm the second paaaaagegege!</h3>
@for (int i=0; i<number; i++) {
    <div style="width:30px; height: 30px; background-color:rgb(@(rnd.Next(255)), @(rnd.Next(255)), @(rnd.Next(255)))"></div>
}