        }
        else { luokka = "background-color:blue;"; }
        <td style="@luokka">*/
        
        <tbody>
            <tr>
                <td >@mopo.Merkki</td>
                <td>@mopo.Malli</td>
                <td>@mopo.Vuosi</td>
                <td>@mopo.Vari</td>
            </tr>
        </tbody>
        }
