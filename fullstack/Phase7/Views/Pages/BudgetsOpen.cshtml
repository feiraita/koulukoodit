@{
    ViewData["Title"] = "Budgets Tab";
}
@using Phase7.Models.ViewModels
@model CategoryViewModel

<div class="col-10 col-lg-6 col-xl-4 mx-auto">
    <div class="py-4 d-flex justify-content-between">
        <a role="button" href="/Pages/Budgets" class="w-25 btn btn-custom-back">Go Back</a>
        <button type="button" class="w-25 btn openModal-btn btn-custom-back"
                data-target="_EditCategory" data-id="@Model.categoryID" data-title="Edit Category">Edit
        </button>
    </div>
 
    <!-- Modaali delete-->
    <div class="modal" id="myModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle"></h5>
                    <button type="button" class="btn-close" 
                    data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="modalBody"></div>
            </div>
        </div>
    </div>

    <div class="card shadow w-100">
        <div class="card-header">
            <h4 class="mt-2">@Model.name</h4>
                @if(Model.monthlyLimit == false) {
                    <p class="mb-1">No limit</p>   
                } else { 
                    <p>Used this month: @Model.total € </p>
                    <p> Monthly limit: @Model.amount €</p>
                    @if (@Model.total > @Model.amount) {
                        <p style="color:red;"> You're @(Model.total - Model.amount) € over the monthly limit!</p>
                    } else {
                        <p style="color:green;"> You still have @(Model.total - Model.amount) € left this month!</p>
                    } 
                }
        </div>
        <div class="card-body">
            <h5>Transaction History</h5>
            @if (!Model.Expenses.Any()) {
                <p class="mb-1">No previous transactions</p> 
            } else {
                @foreach (var expense in Model.Expenses) {
                    <div class="d-flex justify-content-between">
                        <p>@expense.date.ToShortDateString()</p>
                        <p class="fw-bold">@expense.amount €</p>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
$(".openModal-btn").on("click", function () {
    var target = $(this).data("target");
    var id = $(this).data("id");
    var title = $(this).data("title");

    $.ajax({
        type: 'GET',
        url: '/Pages/' + target,
        data: { id: id, title: title },
        success: function (result) {
            $("#modalBody").html(result);
            $("#modalTitle").text(title);

            var modal = new bootstrap.Modal(document.getElementById('myModal'));
            modal.show();

            function toggleAmount() {
            const value = $(".monthlyLimit").val();

            if (value === "true") {
                $("#amountGroup").show();
            } else {
                $("#amountGroup").hide();
            }
        }
        toggleAmount();
        $(document).on("change", ".monthlyLimit", toggleAmount);
        },
        error: function () {
            alert("Failed to load partial view.");
        }
    });
});
</script>
}