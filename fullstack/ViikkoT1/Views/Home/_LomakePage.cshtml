@using ViikkoT1.Models.ViewModel
@model LomakePageViewModel
         
<form id="lomakeForm" asp-controller="Home" asp-action="_LomakePage" method="post" class="partial-lomake d-flex justify-content-center py-3">
        <div class="card" style="width: 18rem;">
            <div class="card-body text-left">
                <h5 class="card-title">Partial Lomake</h5>

                <div class="form-group py-2">
                    <label asp-for="first" class="label-control"></label>
                    <input asp-for="first" onfocus="this.value=''" min="1" max="100" required class="form-control" />
                </div>
                <div class="form-group py-2">
                    <label asp-for="second" class="label-control"></label>
                    <input asp-for="second" onfocus="this.value=''" min="1" max="100" required class="form-control"/>
                </div>
                <div class="form-group py-2 d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary">Submit</button>
                </div>
                
            </div>
        </div>
</form>